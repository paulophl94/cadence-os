{
  "version": "1.0.0",
  "skills": [
    {
      "id": "morning-briefing",
      "name": "Morning Briefing",
      "category": "daily-workflow",
      "triggers": ["morning briefing", "start the day", "what's on today"],
      "inputs": [
        ".cursor/rules/product-context.mdc",
        "global-context/{domain}/DOMAIN-VISION.md",
        "global-context/{domain}/ROADMAP.md",
        "global-context/shared/pillars.md",
        "global-context/shared/assumptions.md",
        "to_do's/quarter-goals.md",
        "to_do's/week-priorities.md",
        "to_do's/commitments.md",
        "to_do's/tasks.md",
        "cadence-progress.json",
        "context/people/*.md",
        "wiki/INDEX.md"
      ],
      "outputs": [
        "to_do's/briefings/YYYY-MM-DD.md",
        "to_do's/progress-log.md",
        "to_do's/tasks.md"
      ],
      "integrations": ["calendar", "fireflies", "jira", "browser"],
      "estimated_time": "3-5 min",
      "depends_on": []
    },
    {
      "id": "daily-review",
      "name": "Daily Review",
      "category": "daily-workflow",
      "triggers": ["daily review", "end of day", "close the day"],
      "inputs": [
        "to_do's/tasks.md",
        "to_do's/briefings/YYYY-MM-DD.md",
        "to_do's/week-priorities.md",
        "to_do's/commitments.md",
        "cadence-progress.json",
        "wiki/**/*.md"
      ],
      "outputs": [
        "to_do's/reviews/YYYY-MM-DD.md",
        "to_do's/tasks.md",
        "to_do's/learnings/preferences.md",
        "to_do's/learnings/patterns.md"
      ],
      "integrations": [],
      "estimated_time": "5-10 min",
      "depends_on": ["morning-briefing"]
    },
    {
      "id": "weekly-review",
      "name": "Weekly Review",
      "category": "weekly-workflow",
      "triggers": ["weekly review", "close the week", "friday review"],
